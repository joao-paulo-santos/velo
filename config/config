# Config for velo
#
# Copy this file to ~/.config/velo/config and get customising.
# Every option is listed below: active ones set, optional ones commented out.
# Any option can also be passed as a long flag, e.g.  velo --font-size 14.

### Colors
# Colors come from a palette JSON. See doc/palette.md for the format and how
# to create your own. List installed palettes with: velo --list-palettes
# palette = filename in ~/.config/velo/palettes/ minus the .json suffix.
palette = "adw"
# darkmode = true uses the palette's dark variant; false uses light.
darkmode = true
# Auto-adjust colors for readability (default). When on, velo derives colors
# that would otherwise be invisible against the background (e.g. the selection
# tint on flat/monochrome palettes). Turn off to use palette roles verbatim.
color-derivation = true
# Background transparency, 0.1 (ghost) to 1.0 (opaque).
background-opacity = 0.8
# Render the selected entry as a filled bar (primary background + onPrimary
# text) instead of colored text.
selection-box = false
# Highlight the matched characters in each result (default off). The highlight
# color is derived for readability; remap it via palette_color_mapping.json.
match-highlight = true
# To remap which palette role (surface/onSurface/primary/...) fills which render
# slot (background/text/selection/border/prompt/divider), edit
# palette_color_mapping.json next to this file. See doc/palette.md.

### Fonts
font = Sans
font-size = 14

### Window
width = 400
height = 600
border-width = 2
corner-radius = 8
# Inner padding on all sides. Override per side with the options below.
padding = 16
# padding-top = 16
# padding-bottom = 16
# padding-left = 16
# padding-right = 16

### Sizing
# Dynamic window height: grow/shrink to fit the visible results (Spotlight-like).
# When enabled, anchor is forced to top and the window is centered vertically.
autosize = true

### Positioning
# Restrict to a named output. Default: first detected output.
# output = eDP-1
# Where on screen to anchor. One of: top-left, top, top-right, right,
# bottom-right, bottom, bottom-left, left, center.
anchor = center
margin-top = 0
margin-bottom = 0
margin-left = 0
margin-right = 0

### Text
prompt-text = "> "

### Plugins
# Comma-separated list of plugins to show. Use "all" to enable every plugin,
# prefix a name with "-" to exclude it.
#   plugins = all
#   plugins = all,-drun
#   plugins = apps,windows
plugins = all
