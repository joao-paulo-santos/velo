# velo config

palette = "catppuccin-lavender"
darkmode = true

autosize = true

# Font settings
font = "/usr/share/fonts/TTF/JetBrainsMonoNerdFont-Regular.ttf"
font-size = 14

# Background transparency (0.1-1.0)
background-opacity = 0.85

# Window dimensions
width = 600
height = 400

# Border and corners
border-width = 2
corner-radius = 3

# Padding
padding = 16

# Positioning
# anchor = center
# margin-top = 0
# margin-bottom = 0
# margin-left = 0
# margin-right = 0

# Output (monitor to display on)
# output =

# Prompt
prompt-text = "> "

# Plugins - comma-separated list
# Use "all" to enable all, "-name" to exclude
plugins = all
