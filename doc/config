# Config for velo
#
# Copy this file to ~/.config/velo/config and get customising!

### Fonts
font = Sans
font-size = 24

### Palette
# Color palette (filename in ~/.config/velo/palettes/, minus .json).
# List installed palettes: velo --list-palettes
# See doc/palette.md to create your own.
palette = breeze
# darkmode = true uses the palette's dark variant; false uses light.
darkmode = true
# Background transparency (0.1-1.0).
background-opacity = 0.85

### Window
width = 600
height = 400
border-width = 2
corner-radius = 0
padding = 16

### Positioning
# output = eDP-1
anchor = center
margin-top = 0
margin-bottom = 0
margin-left = 0
margin-right = 0

### Text
prompt-text = "> "

### Plugins
# Comma-separated list of plugins to enable
# Use "all" to enable all, "-name" to exclude
# Examples:
#   plugins = all
#   plugins = all,-drun
#   plugins = apps,windows
plugins = all
